# --- OpenClaw Sensitive Data ---
.openclaw/
.openclaw-architect/
**/sessions/
**/auth/
**/keys.json
**/config.local.json
.env
.env.local

# --- macOS System Files ---
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes

# --- Node.js / Dependencies ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Python / OSINT Tools ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/

# --- Media & Large Assets ---
# Don't track the actual videos/images being generated
**/output/
**/temp_renders/
*.mp4
*.mov
*.png
*.jpg
*.jpeg
!assets/logo.png  # Example: Keep your brand logo, ignore the rest

# --- Logs & Performance ---
*.log
logs/
pids/
*.pid
*.seed
*.pid.lock

# Media files - never commit
media/output/
media/raw/
media/temp/
daily/
memory/archive/
*.png
*.jpg
*.jpeg
*.webp
*.gif
*.mp4
*.mov
*.webm
*.mp3
*.wav
*.flac
*.log
.DS_Store

# Daily memory and runtime files - keep local only
memory/
daily/
memory/archive/
secrets.env
*.key
